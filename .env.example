# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Security (REQUIRED for production) ──────────────────────────────────────
# Generate: node -e "process.stdout.write(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGIN=http://localhost:3000

# ─── Database ─────────────────────────────────────────────────────────────────
DB_PATH=./database.sqlite

# ─── App Branding ─────────────────────────────────────────────────────────────
APP_NAME=ProjectFlow
APP_URL=http://localhost:3000

# ─── Email (optional — emails are skipped if SMTP_USER is not set) ────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@email.com
SMTP_PASS=your-app-password
EMAIL_FROM=ProjectFlow <noreply@projectflow.com>
